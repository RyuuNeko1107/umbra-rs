     /// WGS84（conventions §4.1）。
     pub const WGS84: Ellipsoid = Ellipsoid {
         a_m: EARTH_EQUATORIAL_RADIUS_M,
         f: WGS84_FLATTENING,
     };
 
     /// 短半径 b = a(1 − f) \[m\]。
     pub fn b_m(&self) -> f64 {
-        self.a_m * (1.0 - self.f)
+        -1.0 /* ~ changed by cargo-mutants ~ */
