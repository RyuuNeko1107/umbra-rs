 /// 測地緯度 → 地心緯度（rad）。`tan φ′ = (1 − e²) tan φ`。
 pub fn geodetic_to_geocentric_latitude(ellipsoid: &Ellipsoid, geodetic_lat: f64) -> f64 {
     ((1.0 - ellipsoid.e2()) * geodetic_lat.tan()).atan()
