     /// x 軸まわりの座標回転 R1(θ)。
     pub fn rotation_x(theta: f64) -> Matrix3 {
         let (s, c) = theta.sin_cos();
         Matrix3::new([[1.0, 0.0, 0.0], [0.0, c, s], [0.0, -s, c]])
     }
 
